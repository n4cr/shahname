---
import { getCollection, type CollectionEntry } from "astro:content";
import Base from "../../layouts/Base.astro";
import { parseVerses } from "../../lib/poem";
import { loadAllSources, loadSource } from "../../lib/sources";
import { u } from "../../lib/url";

export async function getStaticPaths() {
  const sources = loadAllSources();
  const highlightsById = new Map<string, CollectionEntry<"stories">>();
  for (const h of await getCollection("stories")) {
    highlightsById.set(h.id, h);
  }
  return sources.map((src) => ({
    params: { id: src.id },
    props: { source: src, highlight: highlightsById.get(src.id) ?? null },
  }));
}

interface Props {
  source: ReturnType<typeof loadSource> & object;
  highlight: CollectionEntry<"stories"> | null;
}

const { source, highlight } = Astro.props;
const h = highlight?.data ?? null;

// Title and chapter label come from the highlight if present, otherwise
// fall back to whatever we can derive from the source file.
const chapterFa = h?.chapter.fa ?? `داستان ${source.id}`;
const titleFa = h?.title.fa ?? source.rawTitle;
const subtitleFa = h?.subtitle?.fa;

// Verses: prefer the cleaned text from the highlight YAML, fall back to raw .txt
const stanzas = parseVerses(h?.versesFa ?? source.versesFa);
const hasVerses = stanzas.length > 0;
const hasProse = (h?.prose.fa.length ?? 0) > 0;
const hasEnglish = !!h?.prose.en && h.prose.en.length > 0;

// If this entry has no verses and no highlight, treat it as a SECTION header.
// Surface the stories that belong to this section (until the next section marker)
// as a small in-page index.
const allSources = loadAllSources();
const myIdx = allSources.findIndex((s) => s.id === source.id);
const isSectionHead = !hasVerses && !hasProse;
let sectionChildren: { id: string; title: string }[] = [];
if (isSectionHead && myIdx >= 0) {
  for (let i = myIdx + 1; i < allSources.length; i++) {
    const next = allSources[i];
    if (next.versesFa.trim().length === 0) break;
    sectionChildren.push({ id: next.id, title: next.rawTitle });
  }
}

function applyEmphasis(s: string): string {
  return s.replace(
    /\*([^*]+)\*/g,
    (_, t) => `<em class="em">${t}</em>`,
  );
}
---

<Base
  title={`${titleFa} — شاهنامه`}
  description={subtitleFa}
  lang="fa"
  altLangHref={hasEnglish ? u(`/en/stories/${source.id}`) : undefined}
>
  <div class="page">
    <nav class="top-nav" aria-label="پیمایش">
      <a class="back" href={u("/")}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="14" height="14" aria-hidden="true">
          <path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>شاهنامه</span>
      </a>
      <span class="crumb-sep" aria-hidden="true">·</span>
      <a class="crumb-link" href={u("/stories")}>فهرستِ داستان‌ها</a>
    </nav>

    <section class="story-head">
      <div class="chapter-num">{chapterFa}</div>
      <h1 class="story-title">{titleFa}</h1>
      {subtitleFa && <div class="story-subtitle">{subtitleFa}</div>}
    </section>

    {h?.hero && (
      <figure class="illumination">
        <img src={u(h.hero.src)} alt={h.hero.alt.fa} loading="lazy" />
        <figcaption>{h.hero.caption.fa}</figcaption>
      </figure>
    )}

    {hasProse && (
      <div class="view-switch" role="tablist">
        <button type="button" data-view="narrative" class="is-active" role="tab" aria-selected="true">روایت روان</button>
        {hasVerses && (
          <button type="button" data-view="verse" role="tab" aria-selected="false">شعر فردوسی</button>
        )}
        {hasEnglish && (
          <button type="button" data-view="english" role="tab" aria-selected="false">English</button>
        )}
      </div>
    )}

    {hasProse && h && (
      <article class="panel is-active card" id="panel-narrative" role="tabpanel">
        {h.cast.length > 0 && (
          <div class="cast">
            <h3>چهره‌های داستان</h3>
            <dl>
              {h.cast.map((c) => (
                <>
                  <dt>{c.fa}</dt>
                  <dd>{c.roleFa}</dd>
                </>
              ))}
            </dl>
          </div>
        )}
        <div class="prose">
          {h.prose.fa.map((p, i) =>
            p === "::quote::" && h.pullQuote ? (
              <div class="pull">{h.pullQuote.fa}</div>
            ) : (
              <p class={i === 0 ? "lead" : ""} set:html={applyEmphasis(p)} />
            ),
          )}
        </div>
      </article>
    )}

    {hasProse && hasEnglish && h?.prose.en && (
      <article class="panel card" id="panel-english" lang="en" dir="ltr" role="tabpanel" hidden>
        <div class="prose en">
          {h.prose.en.map((p, i) =>
            p === "::quote::" && h.pullQuote?.en ? (
              <div class="pull">{h.pullQuote.en}</div>
            ) : (
              <p class={i === 0 ? "lead" : ""} set:html={applyEmphasis(p)} />
            ),
          )}
        </div>
      </article>
    )}

    {hasVerses && (
      <article
        class={`panel card verse-panel${hasProse ? "" : " is-active no-tabs"}`}
        id="panel-verse"
        role="tabpanel"
        hidden={hasProse}
      >
        {stanzas.map((st, i) => (
          <>
            {i > 0 && <div class="section-break" aria-hidden="true">❖</div>}
            <div class="stanza">
              {st.couplets.map((c) => (
                <>
                  <p class="mesra first">{c.first}</p>
                  <p class="mesra second">{c.second}</p>
                </>
              ))}
            </div>
          </>
        ))}
      </article>
    )}

    {isSectionHead && sectionChildren.length > 0 && (
      <article class="card section-card">
        <p class="section-intro">
          این عنوان، آغازِ بخشِ
          <b>«{titleFa}»</b>
          از شاهنامه است. داستان‌های این بخش:
        </p>
        <ol class="children">
          {sectionChildren.map((c) => (
            <li>
              <a href={u(`/stories/${c.id}`)}>
                <span class="cnum">{c.id}</span>
                <span class="ctitle">{c.title}</span>
                <span class="carrow" aria-hidden="true">←</span>
              </a>
            </li>
          ))}
        </ol>
      </article>
    )}

    {isSectionHead && sectionChildren.length === 0 && (
      <article class="card" style="text-align: center;">
        <p style="color: var(--ink-faint); font-family: 'Amiri', serif;">
          این بخش از کتاب در نسخه‌ی ما تنها به‌عنوان عنوان آمده است.
        </p>
      </article>
    )}

    <footer>
      <div class="colophon">به یاد فردوسی، که زبان پارسی را زنده داشت</div>
      <div class="colophon-quote">«بسی رنج بردم در این سال سی &nbsp;•&nbsp; عجم زنده کردم بدین پارسی»</div>
    </footer>
  </div>

  {hasProse && (
    <script is:inline>
      (function () {
        const buttons = document.querySelectorAll(".view-switch button[data-view]");
        const panels = {
          narrative: document.getElementById("panel-narrative"),
          verse: document.getElementById("panel-verse"),
          english: document.getElementById("panel-english"),
        };
        function activate(view) {
          buttons.forEach(function (b) {
            const on = b.dataset.view === view;
            b.classList.toggle("is-active", on);
            b.setAttribute("aria-selected", on ? "true" : "false");
          });
          Object.keys(panels).forEach(function (key) {
            const el = panels[key];
            if (!el) return;
            const on = key === view;
            el.classList.toggle("is-active", on);
            if (on) el.removeAttribute("hidden");
            else el.setAttribute("hidden", "");
          });
          try { history.replaceState(null, "", "#" + view); } catch (e) {}
        }
        buttons.forEach(function (b) {
          b.addEventListener("click", function () { activate(b.dataset.view); });
        });
        const initial = (location.hash || "").replace("#", "");
        if (initial in panels) activate(initial);
      })();
    </script>
  )}

  <style>
    .page { max-width: 880px; margin: 0 auto; padding: 60px 24px 120px; }

    .top-nav {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 14px;
      margin-bottom: 24px;
      font-family: "Vazirmatn", sans-serif;
      font-size: 13px;
      color: var(--ink-faint);
    }
    .top-nav .back, .top-nav .crumb-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--ink-dim);
      text-decoration: none;
      padding: 6px 12px;
      border: 1px solid rgba(212, 166, 74, 0.25);
      border-radius: 999px;
      transition: color .2s, border-color .2s, background .2s;
    }
    .top-nav .back:hover, .top-nav .crumb-link:hover {
      color: var(--gold);
      border-color: var(--gold);
      background: rgba(212, 166, 74, 0.08);
    }
    .top-nav .back svg { transform: scaleX(-1); }
    .top-nav .crumb-sep { color: var(--ink-faint); }

    .story-head { text-align: center; padding: 24px 0 8px; }
    .chapter-num {
      font-family: "Vazirmatn", sans-serif;
      font-size: 13px;
      color: var(--gold-deep);
      letter-spacing: 0.3em;
      font-weight: 500;
    }
    .story-title {
      font-family: "Gulzar", serif;
      font-size: clamp(40px, 6vw, 64px);
      color: var(--gold);
      margin: 8px 0 0;
      font-weight: 400;
      line-height: 1.3;
    }
    .story-subtitle {
      font-family: "Amiri", serif;
      color: var(--ink-dim);
      font-size: 22px;
      margin-top: 14px;
    }

    .illumination {
      margin: 48px auto 0;
      max-width: 760px;
      padding: 14px;
      background: linear-gradient(180deg, rgba(212, 166, 74, 0.18), rgba(212, 166, 74, 0.05));
      border: 1px solid rgba(212, 166, 74, 0.35);
      box-shadow: 0 0 0 1px rgba(212, 166, 74, 0.05) inset, 0 30px 80px rgba(0, 0, 0, 0.55);
      position: relative;
    }
    .illumination::before, .illumination::after {
      content: "";
      position: absolute;
      width: 22px; height: 22px;
      border: 1px solid var(--gold);
      opacity: 0.7;
    }
    .illumination::before { top: -1px; right: -1px; border-bottom: none; border-left: none; }
    .illumination::after  { bottom: -1px; left: -1px;  border-top: none;   border-right: none; }
    .illumination img { display: block; width: 100%; height: auto; }
    .illumination figcaption {
      margin-top: 12px;
      text-align: center;
      font-family: "Amiri", serif;
      font-size: 15px;
      color: var(--ink-faint);
      font-style: italic;
    }

    .view-switch {
      display: flex;
      gap: 6px;
      justify-content: center;
      margin: 48px auto 0;
      padding: 6px;
      background: rgba(20, 24, 42, 0.7);
      border: 1px solid rgba(212, 166, 74, 0.2);
      border-radius: 999px;
      width: fit-content;
      backdrop-filter: blur(4px);
    }
    .view-switch button {
      background: transparent;
      border: none;
      color: var(--ink-dim);
      font-family: "Vazirmatn", sans-serif;
      font-size: 14px;
      font-weight: 500;
      padding: 10px 22px;
      border-radius: 999px;
      cursor: pointer;
      transition: color .25s, background .25s;
    }
    .view-switch button:hover { color: var(--ink); }
    .view-switch button.is-active {
      background: linear-gradient(180deg, var(--gold), var(--gold-deep));
      color: #1a1208;
      box-shadow: 0 0 18px rgba(212, 166, 74, 0.35);
    }

    .panel { display: none; }
    .panel.is-active { display: block; }

    .card {
      margin-top: 32px;
      padding: 48px clamp(16px, 5vw, 72px);
      background: linear-gradient(180deg, rgba(26, 29, 46, 0.6), rgba(20, 24, 42, 0.85));
      border: 1px solid rgba(212, 166, 74, 0.18);
      box-shadow: 0 0 0 1px rgba(212, 166, 74, 0.05) inset, 0 20px 60px rgba(0, 0, 0, 0.5);
      position: relative;
    }
    .card::before, .card::after {
      content: "";
      position: absolute;
      width: 36px; height: 36px;
      border: 1px solid var(--gold-deep);
      opacity: 0.6;
    }
    .card::before { top: 10px; right: 10px; border-bottom: none; border-left: none; }
    .card::after  { bottom: 10px; left: 10px;  border-top: none;   border-right: none; }

    .cast {
      margin: 0 0 28px;
      padding: 20px 24px;
      border: 1px dashed rgba(212, 166, 74, 0.25);
      background: rgba(13, 15, 26, 0.4);
    }
    .cast h3 {
      margin: 0 0 12px;
      font-family: "Amiri", serif;
      font-weight: 700;
      font-size: 20px;
      color: var(--gold);
    }
    .cast dl {
      margin: 0;
      display: grid;
      grid-template-columns: max-content 1fr;
      column-gap: 18px;
      row-gap: 6px;
      font-size: 15px;
    }
    .cast dt { color: var(--gold-deep); font-weight: 600; }
    .cast dd { margin: 0; color: var(--ink-dim); }

    .prose {
      font-family: "Vazirmatn", sans-serif;
      font-size: clamp(16px, 1.7vw, 19px);
      line-height: 2.1;
      color: var(--ink);
      max-width: 68ch;
      margin: 0 auto;
    }
    .prose.en {
      font-family: Georgia, "Iowan Old Style", serif;
      direction: ltr;
      text-align: left;
      font-size: clamp(16px, 1.7vw, 18px);
      line-height: 1.8;
    }
    .prose p { margin: 0 0 1.2em; text-align: justify; }
    .prose .lead { font-size: 1.08em; }
    .prose .lead::first-letter {
      font-family: "Gulzar", serif;
      font-size: 2.6em;
      line-height: 0.9;
      color: var(--gold);
      float: right;
      margin-left: 8px;
      margin-top: 4px;
      padding-left: 4px;
    }
    .prose.en .lead::first-letter {
      float: left;
      margin-right: 10px;
      margin-left: 0;
      padding-right: 4px;
    }
    .prose :global(.em) {
      color: var(--gold);
      font-style: normal;
      font-weight: 600;
    }
    .pull {
      margin: 32px 0;
      padding: 18px 26px;
      border-inline-start: 2px solid var(--gold-deep);
      color: var(--ink);
      font-family: "Amiri", serif;
      font-size: 1.35em;
      line-height: 1.9;
      background: rgba(212, 166, 74, 0.04);
    }

    .verse-panel.no-tabs { margin-top: 48px; }

    .section-card { margin-top: 48px; }
    .section-intro {
      font-family: "Amiri", serif;
      font-size: 18px;
      color: var(--ink-dim);
      line-height: 2;
      text-align: center;
      margin: 0 0 28px;
    }
    .section-intro b { color: var(--gold); font-weight: 700; }
    .children {
      list-style: none;
      padding: 0;
      margin: 0;
      max-width: 640px;
      margin-inline: auto;
    }
    .children li { border-bottom: 1px solid rgba(212, 166, 74, 0.1); }
    .children a {
      display: grid;
      grid-template-columns: 48px 1fr 24px;
      gap: 16px;
      align-items: center;
      padding: 12px 14px;
      color: var(--ink);
      text-decoration: none;
      transition: background .2s, color .2s;
    }
    .children a:hover { background: rgba(212, 166, 74, 0.05); color: var(--gold-bright); }
    .cnum {
      font-family: "Vazirmatn", sans-serif;
      font-variant-numeric: tabular-nums;
      font-size: 12px;
      color: var(--ink-faint);
      text-align: center;
    }
    .ctitle { font-family: "Amiri", serif; font-size: 17px; }
    .carrow { color: var(--gold); text-align: center; }

    .stanza {
      display: grid;
      grid-template-columns: 1fr 1fr;
      column-gap: clamp(20px, 5vw, 64px);
      row-gap: 6px;
      margin-bottom: 36px;
      position: relative;
    }
    .stanza::before {
      content: "";
      position: absolute;
      top: 4px; bottom: 4px;
      right: 50%;
      width: 1px;
      background: linear-gradient(to bottom, transparent, rgba(212, 166, 74, 0.15) 15%, rgba(212, 166, 74, 0.15) 85%, transparent);
      transform: translateX(50%);
    }
    .mesra {
      font-family: "Amiri", serif;
      font-size: clamp(20px, 2.2vw, 26px);
      color: var(--ink);
      line-height: 2;
      padding: 2px 6px;
    }
    .mesra.first { text-align: justify; padding-left: 18px; }
    .mesra.second { text-align: justify; padding-right: 18px; }
    .section-break {
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 28px 0 40px;
      color: var(--gold);
      opacity: 0.7;
    }
    .section-break::before, .section-break::after {
      content: "";
      width: 60px;
      height: 1px;
      background: var(--rule);
      margin: 0 14px;
    }

    footer {
      margin-top: 80px;
      text-align: center;
      color: var(--ink-faint);
      font-size: 13px;
      line-height: 2;
    }
    footer .colophon {
      font-family: "Amiri", serif;
      color: var(--ink-dim);
      font-size: 19px;
      margin-bottom: 10px;
    }
    footer .colophon-quote {
      font-family: "Amiri", serif;
      font-size: 17px;
    }

    @media (max-width: 640px) {
      .page { padding: 32px 12px 80px; }
      .card { padding: 32px 16px; }
      .stanza { grid-template-columns: 1fr; row-gap: 0; }
      .stanza::before { display: none; }
      .mesra.first, .mesra.second { padding: 0; text-align: right; }
      .mesra.first { padding-bottom: 4px; }
      .mesra.second { padding-bottom: 12px; color: var(--ink-dim); }
    }
  </style>
</Base>
