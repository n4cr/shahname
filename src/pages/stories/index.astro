---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { loadAllSources } from "../../lib/sources";
import { u } from "../../lib/url";
import tocData from "../../../toc.json";

interface TocEntry {
  title: string;
  printed_page: number;
  pdf_page: number;
}
const toc = tocData as TocEntry[];

const sources = loadAllSources();
const highlightIds = new Set((await getCollection("stories")).map((h) => h.id));

interface Item {
  id: string;
  title: string;
  isHighlighted: boolean;
  hasVerses: boolean;
}
interface Section {
  anchor: string;
  title: string;
  startId: string;
  items: Item[];
}

/**
 * ≥ this many TOC dots → section header. The natural gap in the
 * printed TOC sits between sub-headings (≤99 dots) and kingdom/chapter
 * entries (≥101 dots), so 100 cleanly splits them.
 */
const DOTS_THRESHOLD = 100;
/** Detect duplicate reigns by comparing the first noun after "پادشاهی". */
const kingOf = (title: string): string =>
  title.replace(/^پادشاهی\s*/, "").trim().split(/\s+/)[0] ?? "";

const sections: Section[] = [];

sources.forEach((src, i) => {
  const tocEntry = toc[parseInt(src.id, 10) - 1];
  const title = tocEntry?.title?.trim() || src.rawTitle;
  const hasVerses = src.versesFa.trim().length > 0;
  const isReign = title.startsWith("پادشاهی");
  const isHighLevel = src.tocDots >= DOTS_THRESHOLD;

  let startsSection = false;
  if (i === 0) {
    startsSection = true;
  } else if (isHighLevel) {
    startsSection = true;
  } else if (isReign) {
    const last = sections[sections.length - 1];
    const prevWasJustStarted = last && last.items.length === 0;
    const sameKingAsCurrent = last && kingOf(last.title) === kingOf(title);
    if (!prevWasJustStarted && !sameKingAsCurrent) startsSection = true;
  }

  if (startsSection) {
    sections.push({
      anchor: `s-${src.id}`,
      title,
      startId: src.id,
      items: [],
    });
  } else {
    sections[sections.length - 1]?.items.push({
      id: src.id,
      title,
      isHighlighted: highlightIds.has(src.id),
      hasVerses,
    });
  }
});

const highlightedCount = sources.filter((s) =>
  highlightIds.has(s.id),
).length;
---

<Base
  title="فهرستِ شاهنامه — همهٔ داستان‌ها"
  description="فهرستِ کاملِ شاهنامه‌ی فردوسی، گروه‌بندی‌شده برحسبِ پادشاهی‌ها."
  lang="fa"
  altLangHref={u("/en/stories")}
>
  <div class="layout">
    <nav class="top-nav" aria-label="پیمایش">
      <a class="back" href={u("/")}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="14" height="14" aria-hidden="true">
          <path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>شاهنامه</span>
      </a>
    </nav>

    <header class="toc-head">
      <div class="kicker">فهرستِ کامل</div>
      <h1>داستان‌های شاهنامه</h1>
      <p class="lead">
        تمامِ <b>{sources.length}</b> داستانِ شاهنامه در <b>{sections.length}</b> بخش،
        به ترتیبِ کتاب. {highlightedCount} داستان با
        <span class="hl-mark" aria-hidden="true">◆</span>
        دارای روایتِ روانِ امروزی است.
      </p>

      <div class="search">
        <input
          id="toc-search"
          type="search"
          placeholder="جستجوی داستان یا پادشاه…"
          autocomplete="off"
        />
        <span class="count" id="toc-count" aria-live="polite"></span>
      </div>
    </header>

    <div class="grid">
      <aside class="sidebar" aria-label="فهرستِ بخش‌ها">
        <div class="side-label">پادشاهی‌ها</div>
        <ol class="side-list">
          {sections.map((s) => (
            <li>
              <a href={`#${s.anchor}`} data-anchor={s.anchor}>
                <span class="side-num">{s.startId}</span>
                <span class="side-title">{s.title}</span>
                <span class="side-count">{s.items.length}</span>
              </a>
            </li>
          ))}
        </ol>
      </aside>

      <main class="content">
        {sections.map((s) => (
          <section class="section" id={s.anchor}>
            <header class="section-head">
              <span class="section-num" aria-hidden="true">{s.startId}</span>
              <h2 class="section-title">{s.title}</h2>
              <span class="section-count">{s.items.length} داستان</span>
            </header>
            {s.items.length === 0 ? (
              <p class="section-empty">— بخشِ آغازین —</p>
            ) : (
              <ol class="story-list">
                {s.items.map((it) => (
                  <li
                    class={`story-item${it.isHighlighted ? " is-highlight" : ""}${!it.hasVerses ? " is-subheading" : ""}`}
                    data-title={it.title}
                    data-section={s.anchor}
                  >
                    <a href={u(`/stories/${it.id}`)}>
                      <span class="num">{it.id}</span>
                      <span class="title">{it.title}</span>
                      {it.isHighlighted && (
                        <span class="mark" aria-label="دارای روایتِ روان">◆</span>
                      )}
                    </a>
                  </li>
                ))}
              </ol>
            )}
          </section>
        ))}
      </main>
    </div>

    <footer>
      <div class="colophon">به یاد فردوسی، که زبان پارسی را زنده داشت</div>
    </footer>
  </div>

  <script is:inline>
    (function () {
      const input = document.getElementById("toc-search");
      const count = document.getElementById("toc-count");
      const items = Array.from(document.querySelectorAll(".story-item"));
      const sections = Array.from(document.querySelectorAll(".section"));
      const sideLinks = Array.from(document.querySelectorAll(".side-list a"));

      function normalize(s) {
        return (s || "")
          .toLowerCase()
          .replace(/ي/g, "ی")
          .replace(/ك/g, "ک")
          .replace(/[ً-ٰٟ]/g, "")
          .replace(/\s+/g, " ")
          .trim();
      }

      function filter() {
        const q = normalize(input.value);
        if (!q) {
          for (const el of items) el.removeAttribute("hidden");
          for (const el of sections) el.removeAttribute("hidden");
          count.textContent = "";
          return;
        }
        let shown = 0;
        for (const el of items) {
          const t = normalize(el.dataset.title);
          const num = el.querySelector(".num")?.textContent || "";
          const match = t.includes(q) || num.includes(q);
          if (match) { el.removeAttribute("hidden"); shown++; }
          else el.setAttribute("hidden", "");
        }
        // Hide sections that have no visible items
        for (const sec of sections) {
          const anyVisible = sec.querySelector(".story-item:not([hidden])");
          if (anyVisible) sec.removeAttribute("hidden");
          else sec.setAttribute("hidden", "");
        }
        count.textContent = `${shown} نتیجه`;
      }

      input?.addEventListener("input", filter);
      input?.addEventListener("search", filter);

      // Highlight current section in the sidebar as you scroll
      const observer = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            const anchor = e.target.id;
            const link = sideLinks.find((a) => a.dataset.anchor === anchor);
            if (link) link.classList.toggle("is-current", e.isIntersecting);
          }
        },
        { rootMargin: "-30% 0px -65% 0px" },
      );
      for (const sec of sections) observer.observe(sec);
    })();
  </script>

  <style>
    .layout {
      max-width: 1280px;
      margin: 0 auto;
      padding: 60px 24px 120px;
    }

    .top-nav {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 14px;
      margin-bottom: 24px;
      font-family: "Vazirmatn", sans-serif;
      font-size: 13px;
      color: var(--ink-faint);
    }
    .top-nav .back {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--ink-dim);
      text-decoration: none;
      padding: 6px 12px;
      border: 1px solid rgba(212, 166, 74, 0.25);
      border-radius: 999px;
    }
    .top-nav .back:hover {
      color: var(--gold);
      border-color: var(--gold);
      background: rgba(212, 166, 74, 0.08);
    }
    .top-nav .back svg { transform: scaleX(-1); }

    .toc-head { text-align: center; padding: 32px 0 24px; }
    .toc-head .kicker {
      font-family: "Vazirmatn", sans-serif;
      font-size: 12px;
      letter-spacing: 0.4em;
      color: var(--gold-deep);
      font-weight: 500;
      margin-bottom: 16px;
    }
    .toc-head h1 {
      font-family: "Gulzar", serif;
      font-size: clamp(40px, 5vw, 64px);
      color: var(--gold);
      margin: 0;
      font-weight: 400;
    }
    .toc-head .lead {
      max-width: 60ch;
      margin: 24px auto 0;
      font-family: "Amiri", serif;
      font-size: 17px;
      color: var(--ink-dim);
      line-height: 2;
    }
    .toc-head .lead b { color: var(--gold); font-weight: 700; }
    .hl-mark { color: var(--gold); font-size: 0.85em; }

    .search {
      margin: 32px auto 0;
      max-width: 480px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .search input {
      flex: 1;
      padding: 12px 18px;
      background: rgba(13, 15, 26, 0.6);
      border: 1px solid rgba(212, 166, 74, 0.25);
      border-radius: 999px;
      color: var(--ink);
      font-family: "Vazirmatn", sans-serif;
      font-size: 15px;
      outline: none;
      transition: border-color .2s, background .2s;
    }
    .search input:focus {
      border-color: var(--gold);
      background: rgba(13, 15, 26, 0.85);
    }
    .search input::placeholder { color: var(--ink-faint); }
    .search .count {
      font-family: "Vazirmatn", sans-serif;
      font-size: 12px;
      color: var(--ink-faint);
      letter-spacing: 0.05em;
      min-width: 60px;
      text-align: start;
    }

    .grid {
      margin-top: 48px;
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 48px;
      align-items: start;
    }

    /* Sidebar */
    .sidebar {
      position: sticky;
      top: 24px;
      max-height: calc(100vh - 48px);
      overflow-y: auto;
      padding-inline-end: 8px;
      scrollbar-width: thin;
      scrollbar-color: rgba(212, 166, 74, 0.4) transparent;
    }
    .sidebar::-webkit-scrollbar { width: 6px; }
    .sidebar::-webkit-scrollbar-thumb {
      background: rgba(212, 166, 74, 0.3);
      border-radius: 3px;
    }
    .side-label {
      font-family: "Vazirmatn", sans-serif;
      font-size: 11px;
      letter-spacing: 0.35em;
      color: var(--gold-deep);
      font-weight: 500;
      margin-bottom: 16px;
      padding-inline-start: 12px;
    }
    .side-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .side-list a {
      display: grid;
      grid-template-columns: 32px 1fr auto;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      color: var(--ink-dim);
      text-decoration: none;
      border-inline-start: 2px solid transparent;
      font-family: "Vazirmatn", sans-serif;
      font-size: 14px;
      transition: color .15s, background .15s, border-color .15s;
    }
    .side-list a:hover {
      color: var(--gold);
      background: rgba(212, 166, 74, 0.04);
    }
    .side-list a.is-current {
      color: var(--gold);
      border-inline-start-color: var(--gold);
      background: rgba(212, 166, 74, 0.06);
    }
    .side-num {
      font-variant-numeric: tabular-nums;
      font-size: 11px;
      color: var(--ink-faint);
      text-align: center;
    }
    .side-title {
      font-family: "Amiri", serif;
      font-size: 16px;
    }
    .side-count {
      font-family: "Vazirmatn", sans-serif;
      font-size: 11px;
      color: var(--ink-faint);
      font-variant-numeric: tabular-nums;
    }

    /* Content */
    .content { min-width: 0; }

    .section {
      margin-bottom: 56px;
      scroll-margin-top: 24px;
    }
    .section-head {
      display: flex;
      align-items: baseline;
      gap: 16px;
      padding: 12px 4px 16px;
      border-bottom: 1px solid var(--rule);
      margin-bottom: 8px;
    }
    .section-num {
      font-family: "Vazirmatn", sans-serif;
      font-variant-numeric: tabular-nums;
      font-size: 12px;
      color: var(--ink-faint);
      letter-spacing: 0.1em;
      min-width: 40px;
    }
    .section-title {
      font-family: "Gulzar", serif;
      font-weight: 400;
      font-size: clamp(28px, 3.2vw, 40px);
      color: var(--gold);
      margin: 0;
      flex: 1;
      line-height: 1.2;
    }
    .section-count {
      font-family: "Vazirmatn", sans-serif;
      font-size: 12px;
      color: var(--ink-faint);
      letter-spacing: 0.05em;
    }
    .section-empty {
      font-family: "Amiri", serif;
      color: var(--ink-faint);
      font-style: italic;
      padding: 8px 4px;
    }

    .story-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .story-item {
      border-bottom: 1px solid rgba(212, 166, 74, 0.08);
    }
    .story-item a {
      display: grid;
      grid-template-columns: 48px 1fr 24px;
      align-items: center;
      gap: 16px;
      padding: 10px 12px;
      text-decoration: none;
      color: var(--ink);
      transition: background .15s, color .15s;
    }
    .story-item a:hover {
      background: rgba(212, 166, 74, 0.05);
      color: var(--gold-bright);
    }
    .num {
      font-family: "Vazirmatn", sans-serif;
      font-variant-numeric: tabular-nums;
      font-size: 12px;
      letter-spacing: 0.08em;
      color: var(--ink-faint);
      text-align: center;
    }
    .title {
      font-family: "Amiri", serif;
      font-size: 17px;
      line-height: 1.5;
    }
    .mark { color: var(--gold); font-size: 14px; text-align: center; }
    .story-item.is-highlight .title { color: var(--gold); }
    .story-item.is-highlight {
      background: linear-gradient(90deg, rgba(212, 166, 74, 0.04), transparent 80%);
    }
    .story-item.is-subheading .title {
      color: var(--ink-faint);
      font-style: italic;
      font-size: 16px;
    }
    .story-item.is-subheading .num { opacity: 0.55; }

    footer {
      margin-top: 80px;
      text-align: center;
      color: var(--ink-faint);
      font-size: 13px;
      line-height: 2;
    }
    .colophon {
      font-family: "Amiri", serif;
      color: var(--ink-dim);
      font-size: 17px;
    }

    @media (max-width: 880px) {
      .grid { grid-template-columns: 1fr; gap: 24px; }
      .sidebar {
        position: static;
        max-height: none;
        overflow: visible;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--rule);
      }
      .side-list {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }
      .side-list a {
        grid-template-columns: auto auto auto;
        padding: 6px 12px;
        border: 1px solid rgba(212, 166, 74, 0.2);
        border-radius: 999px;
        border-inline-start: 1px solid rgba(212, 166, 74, 0.2);
      }
      .side-list a.is-current {
        border-color: var(--gold);
        border-inline-start: 1px solid var(--gold);
      }
    }
    @media (max-width: 640px) {
      .layout { padding: 36px 12px 80px; }
      .story-item a { grid-template-columns: 40px 1fr 20px; padding: 10px 8px; gap: 10px; }
      .title { font-size: 16px; }
    }
  </style>
</Base>
