---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { loadAllSources } from "../../lib/sources";
import { u } from "../../lib/url";
import tocData from "../../../toc.json";

interface TocEntry {
  title: string;
  printed_page: number;
  pdf_page: number;
}
const toc = tocData as TocEntry[];

const sources = loadAllSources();
const highlightIds = new Set((await getCollection("stories")).map((h) => h.id));

// Combine source list with TOC titles. Sources are sorted by id;
// toc.json is parallel-indexed (entry i ↔ story i+1).
const entries = sources.map((src) => {
  const tocEntry = toc[parseInt(src.id, 10) - 1];
  return {
    id: src.id,
    title: tocEntry?.title?.trim() || src.rawTitle,
    isHighlighted: highlightIds.has(src.id),
    hasVerses: src.versesFa.trim().length > 0,
  };
});

const highlightedCount = entries.filter((e) => e.isHighlighted).length;
---

<Base
  title="فهرستِ شاهنامه — همهٔ داستان‌ها"
  description="فهرستِ کامل ۶۷۹ داستانِ شاهنامه‌ی فردوسی، با نشانه‌ی داستان‌های دارای روایتِ روان."
  lang="fa"
  altLangHref={u("/en/stories")}
>
  <div class="page">
    <nav class="top-nav" aria-label="پیمایش">
      <a class="back" href={u("/")}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="14" height="14" aria-hidden="true">
          <path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <span>شاهنامه</span>
      </a>
    </nav>

    <header class="toc-head">
      <div class="kicker">فهرستِ کامل</div>
      <h1>داستان‌های شاهنامه</h1>
      <p class="lead">
        تمامِ <b>{entries.length}</b> داستانِ شاهنامه، به ترتیبِ کتاب.
        {highlightedCount} داستان با <span class="hl-mark" aria-hidden="true">◆</span>
        دارای روایتِ روانِ امروزی است.
      </p>
    </header>

    <ol class="toc">
      {entries.map((e) => (
        <li class={`toc-item${e.isHighlighted ? " is-highlight" : ""}${!e.hasVerses ? " is-heading" : ""}`}>
          <a href={u(`/stories/${e.id}`)}>
            <span class="num">{e.id}</span>
            <span class="title">{e.title}</span>
            {e.isHighlighted && (
              <span class="mark" aria-label="دارای روایتِ روان">◆</span>
            )}
          </a>
        </li>
      ))}
    </ol>

    <footer>
      <div class="colophon">به یاد فردوسی، که زبان پارسی را زنده داشت</div>
      <div class="colophon-quote">«بسی رنج بردم در این سال سی &nbsp;•&nbsp; عجم زنده کردم بدین پارسی»</div>
    </footer>
  </div>

  <style>
    .page { max-width: 980px; margin: 0 auto; padding: 60px 24px 120px; }

    .top-nav {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 14px;
      margin-bottom: 24px;
      font-family: "Vazirmatn", sans-serif;
      font-size: 13px;
      color: var(--ink-faint);
    }
    .top-nav .back {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--ink-dim);
      text-decoration: none;
      padding: 6px 12px;
      border: 1px solid rgba(212, 166, 74, 0.25);
      border-radius: 999px;
    }
    .top-nav .back:hover {
      color: var(--gold);
      border-color: var(--gold);
      background: rgba(212, 166, 74, 0.08);
    }
    .top-nav .back svg { transform: scaleX(-1); }

    .toc-head { text-align: center; padding: 32px 0 56px; }
    .toc-head .kicker {
      font-family: "Vazirmatn", sans-serif;
      font-size: 12px;
      letter-spacing: 0.4em;
      color: var(--gold-deep);
      font-weight: 500;
      margin-bottom: 16px;
    }
    .toc-head h1 {
      font-family: "Gulzar", serif;
      font-size: clamp(40px, 5vw, 64px);
      color: var(--gold);
      margin: 0;
      font-weight: 400;
    }
    .toc-head .lead {
      max-width: 56ch;
      margin: 24px auto 0;
      font-family: "Amiri", serif;
      font-size: 17px;
      color: var(--ink-dim);
      line-height: 2;
    }
    .toc-head .lead b {
      color: var(--gold);
      font-weight: 700;
    }
    .toc-head .hl-mark { color: var(--gold); font-size: 0.85em; }

    .toc {
      list-style: none;
      padding: 0;
      margin: 0;
      counter-reset: none;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      border-top: 1px solid var(--rule);
    }
    .toc-item { border-bottom: 1px solid rgba(212, 166, 74, 0.12); }
    .toc-item a {
      display: grid;
      grid-template-columns: 56px 1fr 24px;
      align-items: center;
      gap: 16px;
      padding: 14px 16px;
      text-decoration: none;
      color: var(--ink);
      transition: background .2s, color .2s;
      font-family: "Vazirmatn", sans-serif;
    }
    .toc-item a:hover {
      background: rgba(212, 166, 74, 0.05);
      color: var(--gold-bright);
    }
    .num {
      font-family: "Vazirmatn", sans-serif;
      font-variant-numeric: tabular-nums;
      font-size: 12px;
      letter-spacing: 0.1em;
      color: var(--ink-faint);
      text-align: center;
    }
    .title {
      font-family: "Amiri", serif;
      font-size: 18px;
      line-height: 1.5;
    }
    .mark {
      color: var(--gold);
      font-size: 14px;
      text-align: center;
    }

    .toc-item.is-highlight a { color: var(--ink); }
    .toc-item.is-highlight .title { color: var(--gold); }
    .toc-item.is-highlight {
      background: linear-gradient(90deg, rgba(212, 166, 74, 0.04), transparent 80%);
    }

    .toc-item.is-heading .title { color: var(--ink-faint); font-style: italic; }
    .toc-item.is-heading a { cursor: default; }

    footer {
      margin-top: 80px;
      text-align: center;
      color: var(--ink-faint);
      font-size: 13px;
      line-height: 2;
    }
    .colophon {
      font-family: "Amiri", serif;
      color: var(--ink-dim);
      font-size: 19px;
      margin-bottom: 10px;
    }
    .colophon-quote {
      font-family: "Amiri", serif;
      font-size: 17px;
    }

    @media (max-width: 640px) {
      .page { padding: 36px 12px 80px; }
      .toc-item a { grid-template-columns: 44px 1fr 20px; padding: 12px 10px; gap: 10px; }
      .title { font-size: 16px; }
    }
  </style>
</Base>
